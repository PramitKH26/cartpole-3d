<mujoco model="cartpole2d">
  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <asset>
    <texture name="checker" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.2 0.3 0.4" rgb2="0.3 0.4 0.5"/>
    <material name="floor_mat" texture="checker" texrepeat="5 5" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light name="sun" directional="true" pos="0 0 4" dir="0 -0.3 -1" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"/>
    <geom name="floor" type="plane" size="5 5 0.1" material="floor_mat" pos="0 0 -0.5"/>

    <!-- Slider joint on x-axis carries the cart. Range ±2.4 m. -->
    <body name="cart" pos="0 0 0">
      <joint name="slider" type="slide" axis="1 0 0" range="-2.4 2.4" damping="0.5"/>
      <geom name="cart_geom" type="box" size="0.1 0.05 0.05" mass="1.0"
            rgba="0.4 0.6 0.8 1" condim="1"/>

      <!-- Pole: capsule of length 1 m, mass 0.1 kg, hinge at top of cart.
           fromto places the pivot at cart top (z=+0.05) and tip at z=+1.05.
           At qpos[1]=pi, the pole is straight up (upright goal). -->
      <body name="pole" pos="0 0 0.05">
        <joint name="hinge" type="hinge" axis="0 1 0" damping="0.01"/>
        <!-- fromto points DOWN so qpos[hinge]=0 → pole hangs, qpos[hinge]=pi → pole is upright -->
        <geom name="pole_geom" type="capsule" fromto="0 0 0 0 0 -1.0"
              size="0.025" mass="0.1" rgba="0.8 0.4 0.2 1"/>
        <!-- Small sphere to mark the pole tip (upright = z+1 relative to hinge body) -->
        <geom name="pole_tip" type="sphere" size="0.04" pos="0 0 -1.0"
              rgba="1.0 0.2 0.2 1" mass="0"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- gear=10 maps action ∈ [-1,1] → force ∈ [-10,10] N on the slider -->
    <motor name="slide_motor" joint="slider" gear="10" ctrlrange="-1 1" ctrllimited="true"/>
  </actuator>

</mujoco>
