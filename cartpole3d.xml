<mujoco model="cartpole3d">
  <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>

  <asset>
    <texture name="checker" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.2 0.3 0.4" rgb2="0.3 0.4 0.5"/>
    <material name="floor_mat" texture="checker" texrepeat="5 5" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light name="sun" directional="true" pos="0 0 4" dir="0 -0.3 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="5 5 0.1" material="floor_mat" pos="0 0 -0.5"/>

    <!-- Cart: two slider joints give it 2D translation across the floor.
         qpos[0]=cart_x ∈ [-2.4, 2.4],  qpos[1]=cart_y ∈ [-2.4, 2.4]. -->
    <body name="cart" pos="0 0 0">
      <joint name="slide_x" type="slide" axis="1 0 0" range="-2.4 2.4" damping="0.5"/>
      <joint name="slide_y" type="slide" axis="0 1 0" range="-2.4 2.4" damping="0.5"/>
      <geom name="cart_geom" type="box" size="0.1 0.1 0.05" mass="1.0"
            rgba="0.4 0.6 0.8 1" condim="1"/>

      <!-- Pole pivot: two perpendicular hinges in series ≈ a universal joint.
           Both at 0 means pole is straight up (the upright equilibrium).
           qpos[2]=tilt_x (rotation around world x),
           qpos[3]=tilt_y (rotation around world y). -->
      <body name="pivot_x" pos="0 0 0.05">
        <joint name="hinge_x" type="hinge" axis="1 0 0" damping="0.01"/>
        <!-- Tiny inertial — MuJoCo requires moving bodies have nonzero mass.
             Real pole mass lives in the pole_geom below; this is a numerical floor. -->
        <inertial pos="0 0 0" mass="1e-4" diaginertia="1e-6 1e-6 1e-6"/>
        <body name="pivot_y">
          <joint name="hinge_y" type="hinge" axis="0 1 0" damping="0.01"/>
          <!-- Pole extends UP from the pivot. Inverted pendulum: unstable. -->
          <geom name="pole_geom" type="capsule" fromto="0 0 0 0 0 1.0"
                size="0.025" mass="0.1" rgba="0.8 0.4 0.2 1"/>
          <geom name="pole_tip" type="sphere" size="0.04" pos="0 0 1.0"
                rgba="1.0 0.2 0.2 1" mass="0"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Two independent motors: action[0] pushes along x, action[1] along y -->
    <motor name="motor_x" joint="slide_x" gear="10" ctrlrange="-1 1" ctrllimited="true"/>
    <motor name="motor_y" joint="slide_y" gear="10" ctrlrange="-1 1" ctrllimited="true"/>
  </actuator>

</mujoco>
